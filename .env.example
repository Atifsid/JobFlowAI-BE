# PORT
PORT=3000

# HIREBASE
HIREBASE_API_KEY=
HIREBASE_USE_LIVE_API=false

# GREENHOUSE
# Comma-separated public job board tokens, e.g. "stripe,airbnb"
GREENHOUSE_BOARD_TOKENS=

# GOOGLE SHEET
GOOGLE_SHEET_ID=
GOOGLE_SHEET_NAME=

# AI
AI_PROVIDER=claude
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:7b

# LINKEDIN
LINKEDIN_SESSION_PATH=credentials/linkedin-session.json
EMPLOYEE_SEARCH_LIMIT=5

# RESUME PDF + DRIVE
RESUME_PDF_ENABLED=false
DRIVE_UPLOAD_ENABLED=false
# Create a folder in Google Drive and share it with the service
# account's client_email (Editor access) - service accounts have no
# storage quota of their own, so uploads must land inside a shared folder.
GOOGLE_DRIVE_FOLDER_ID=
# Drive uploads authenticate as YOUR Google account (not the service
# account) - service accounts have no Drive storage quota and Google no
# longer honors folder-sharing as a workaround. Create a "Desktop app"
# OAuth Client ID in Google Cloud Console (Drive API enabled on the
# project), set the two vars below, then run `npm run google:drive-login`
# once to authorize and save a token. GOOGLE_DRIVE_FOLDER_ID above is now
# optional (omit it to upload to your Drive root).
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_TOKEN_PATH=credentials/google-oauth-token.json
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=